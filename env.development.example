# Dokploy 开发环境配置示例
# 复制此文件为 .env.development 并根据需要修改

# ======================
# 应用配置
# ======================
NODE_ENV=development
PORT=3000  # 容器内端口，映射到宿主机 23000

# ======================
# 数据库配置
# ======================
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://dokploy:dokploy_dev_password@postgres:5432/dokploy

# 数据库迁移时使用
POSTGRES_USER=dokploy
POSTGRES_PASSWORD=dokploy_dev_password
POSTGRES_DB=dokploy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ======================
# Redis 配置
# ======================
REDIS_URL=redis://redis:6379

# ======================
# Docker Swarm 配置
# ======================
# 服务器 IP 地址（开发环境可以使用 localhost 或容器 IP）
ADVERTISE_ADDR=127.0.0.1

# ======================
# 认证与安全
# ======================
# JWT Secret（用于生成和验证 token）
JWT_SECRET=your-dev-secret-key-change-this

# Session Secret
SESSION_SECRET=your-dev-session-secret-change-this

# Development-only auth bypass for local API debugging
# Set to 1 to impersonate the default owner session in development
# DOKPLOY_DEV_AUTH_BYPASS=1

# 管理员初始密码（首次启动时使用）
ADMIN_PASSWORD=admin123

# ======================
# 应用 URL
# ======================
# 应用访问地址（从宿主机访问）
APP_URL=http://localhost:23000

# API 地址（从宿主机访问）
API_URL=http://localhost:23000/api

# ======================
# 文件存储
# ======================
# 数据存储路径
DATA_DIR=/etc/dokploy

# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE=100

# ======================
# 日志配置
# ======================
# 日志级别: debug, info, warn, error
LOG_LEVEL=debug

# 启用详细日志
VERBOSE_LOGGING=true

# ======================
# 构建工具配置
# ======================
# Nixpacks 版本
NIXPACKS_VERSION=1.39.0

# Railpack 版本
RAILPACK_VERSION=0.2.2

# Checkout scan docker build memory limits.
# These limits are only applied when DOCKER_BUILDKIT=0 because buildx does not
# support --memory. If DOCKER_BUILDKIT is unset or 1, checkout build keeps using
# BuildKit and the memory limit is ignored.
# Example values: 4g, 8192m
# DOCKER_BUILDKIT=0
# DOKPLOY_SCAN_CHECKOUT_BUILD_MEMORY=4g
# DOKPLOY_SCAN_CHECKOUT_BUILD_MEMORY_SWAP=4g

# ======================
# 开发工具配置
# ======================
# 启用热重载
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Next.js 配置
NEXT_TELEMETRY_DISABLED=1

# ======================
# 可选配置
# ======================
# SMTP 邮件配置（可选）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@dokploy.dev

# GitHub OAuth（可选）
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# GitLab OAuth（可选）
# GITLAB_CLIENT_ID=your-gitlab-client-id
# GITLAB_CLIENT_SECRET=your-gitlab-client-secret

# S3 存储配置（可选）
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=dokploy-dev
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1
