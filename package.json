{
	"name": "vulseek",
	"private": true,
	"license": "Apache-2.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"vulseek:setup": "pnpm --filter=vulseek run setup",
		"vulseek:dev": "pnpm --filter=vulseek run dev",
		"vulseek:dev:turbopack": "pnpm --filter=vulseek run dev-turbopack",
		"vulseek:build": "pnpm --filter=vulseek run build",
		"vulseek:start": "pnpm --filter=vulseek run start",
		"test": "pnpm --filter=vulseek run test",
		"server:script": "pnpm --filter=@vulseek/server run switch:dev",
		"server:dev": "pnpm --filter=@vulseek/server run dev",
		"server:build": "pnpm --filter=@vulseek/server run build",
		"typecheck": "pnpm -r run typecheck",
		"build": "pnpm -r run build",
		"format-and-lint": "biome check .",
		"check": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
		"format-and-lint:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.1",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/node": "^18.19.104",
		"dotenv": "16.4.5",
		"esbuild": "0.20.2",
		"lefthook": "1.8.4",
		"lint-staged": "^15.5.2",
		"tsx": "4.16.2"
	},
	"packageManager": "pnpm@9.12.0",
	"engines": {
		"node": "^20.16.0",
		"pnpm": ">=9.12.0"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"resolutions": {
		"@types/react": "18.3.5",
		"@types/react-dom": "18.3.0"
	},
	"pnpm": {
		"patchedDependencies": {
			"sandbox-agent@0.4.2": "packages/server/src/services/dockerfiles/sandbox-agent@0.4.2.patch"
		}
	}
}
