FROM ubuntu:24.04 AS tools

ARG DEBIAN_FRONTEND=noninteractive
ARG CODEQL_VERSION="2.20.6"
ARG RUST_TOOLCHAIN="stable"
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY \
    HTTPS_PROXY=$HTTPS_PROXY \
    NO_PROXY=$NO_PROXY \
    http_proxy=$http_proxy \
    https_proxy=$https_proxy \
    no_proxy=$no_proxy \
    PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
    PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn \
    CARGO_HOME=/root/.cargo \
    RUSTUP_HOME=/root/.rustup \
    RUSTUP_DIST_SERVER=https://mirrors.tuna.tsinghua.edu.cn/rustup \
    RUSTUP_UPDATE_ROOT=https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup

RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.ustc.edu.cn/ubuntu/|g; s|http://security.ubuntu.com/ubuntu/|http://mirrors.ustc.edu.cn/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources

RUN rm -f /etc/apt/apt.conf.d/docker-clean \
    && printf '%s\n' 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
      > /etc/apt/apt.conf.d/keep-cache

RUN --mount=type=cache,id=dokploy-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=dokploy-apt-lists,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget git jq unzip zip tar xz-utils file gnupg \
    openssl libssl3t64 \
    openssh-client ripgrep vim nano less rsync tree \
    build-essential cmake ninja-build make autoconf automake libtool pkg-config \
    patch \
    clang clangd lldb lld gdb \
    python3 python3-pip python3-venv \
    pipx \
    software-properties-common

RUN sed -i 's|http://mirrors.ustc.edu.cn/ubuntu/|https://mirrors.ustc.edu.cn/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources

# Rust toolchain for LibAFL fuzzers.
# LibAFL main currently declares rust-version = "1.89" in crates/libafl/Cargo.toml.
# The Tsinghua rustup mirror exposes the stable channel; as of 2026-05-15
# stable resolves to rustc 1.95.0, which satisfies LibAFL's requirement.
ENV PATH="/root/.cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --profile minimal --default-toolchain "${RUST_TOOLCHAIN}" \
    && mkdir -p "${CARGO_HOME}" \
    && printf '%s\n' \
      '[source.crates-io]' \
      'replace-with = "tuna"' \
      '' \
      '[source.tuna]' \
      'registry = "sparse+https://mirrors.tuna.tsinghua.edu.cn/crates.io-index/"' \
      '' \
      '[registries.tuna]' \
      'index = "sparse+https://mirrors.tuna.tsinghua.edu.cn/crates.io-index/"' \
      > "${CARGO_HOME}/config.toml"
RUN rustc --version && cargo --version

# Node.js (LTS)
RUN --mount=type=cache,id=dokploy-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=dokploy-apt-lists,target=/var/lib/apt/lists,sharing=locked \
    curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get update && apt-get install -y --no-install-recommends nodejs \
    && node --version \
    && npm --version

# Semgrep CLI
RUN python3 -m pip config set global.index-url "$PIP_INDEX_URL" \
    && python3 -m pip config set global.trusted-host "$PIP_TRUSTED_HOST"
RUN --mount=type=cache,id=dokploy-pip-cache,target=/root/.cache/pip,sharing=locked \
    PIPX_BIN_DIR=/usr/local/bin pipx install semgrep \
    && env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy semgrep --version

# Vulseek parsing helpers
RUN --mount=type=cache,id=dokploy-pip-cache,target=/root/.cache/pip,sharing=locked \
    python3 -m venv /opt/vulseek-venv \
    && /opt/vulseek-venv/bin/pip install --upgrade pip \
    && /opt/vulseek-venv/bin/pip install \
      jsonschema \
      tree-sitter \
      tree-sitter-c \
      tree-sitter-cpp

ENV PATH="/opt/vulseek-venv/bin:$PATH"

# LLM Agent CLIs
# Keep Claude non-fatal to avoid blocking build if registry/network fails.
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm config set registry https://registry.npmmirror.com \
    && npm config get registry
COPY sandbox-agent@0.4.2.patch /tmp/dokploy-sandbox-agent.patch
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm install -g @anthropic-ai/claude-code || true
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm install -g sandbox-agent@0.4.2 \
    && patch -d "$(npm root -g)/sandbox-agent" -p1 < /tmp/dokploy-sandbox-agent.patch \
    && grep -R "async loadSession(" "$(npm root -g)/sandbox-agent/dist" >/dev/null \
    && grep -R "async forkSession(" "$(npm root -g)/sandbox-agent/dist" >/dev/null \
    && grep -R "session/close" "$(npm root -g)/sandbox-agent/dist" >/dev/null \
    && grep -R "this.unbindSession(localSessionId, agentSessionId)" "$(npm root -g)/sandbox-agent/dist" >/dev/null \
    && rm -f /tmp/dokploy-sandbox-agent.patch
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm install -g @sandbox-agent/cli@0.4.x \
    && sandbox-agent --help >/dev/null
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm install -g @openai/codex \
    && codex --version
RUN --mount=type=cache,id=dokploy-npm-cache,target=/root/.npm,sharing=locked \
    npm config set registry https://registry.npmjs.org \
    && npm config get registry \
    && sandbox-agent install-agent codex \
    && sandbox-agent install-agent claude
ENV SANDBOX_AGENT_REQUIRE_PREINSTALL=1

# Serena
ENV PATH="/root/.local/bin:$PATH" \
    UV_TOOL_BIN_DIR="/usr/local/bin"
RUN --mount=type=cache,id=dokploy-uv-cache,target=/root/.cache/uv,sharing=locked \
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/usr/local/bin" sh \
    && uv --version \
    && uv tool install -p 3.13 serena-agent@latest --prerelease=allow \
    && mkdir -p /root/.serena \
    && serena init -b LSP \
    && serena setup codex \
    && serena setup claude-code \
    && sed -i 's#^ls_specific_settings: {}#ls_specific_settings:\n  cpp:\n    ls_path: "/usr/bin/clangd"#' /root/.serena/serena_config.yml \
    && sed -i 's#^ignored_paths: \[\]#ignored_paths:\n- "/scan-context"\n- "/scan-context/**"#' /root/.serena/serena_config.yml \
    && sed -i 's#^project_serena_folder_location:.*#project_serena_folder_location: "/scan-context/.serena"#' /root/.serena/serena_config.yml \
    && serena --help >/dev/null

# CodeQL CLI
RUN mkdir -p /opt/codeql \
    && curl -L "https://github.com/github/codeql-cli-binaries/releases/download/v${CODEQL_VERSION}/codeql-linux64.zip" -o /tmp/codeql.zip \
    && unzip -q /tmp/codeql.zip -d /opt \
    && rm -f /tmp/codeql.zip \
    && ln -sf /opt/codeql/codeql /usr/local/bin/codeql
RUN codeql pack download codeql/cpp-all

FROM tools AS codex-acp-builder

ARG CODEX_ACP_REPO="https://github.com/zed-industries/codex-acp.git"
ARG CODEX_ACP_REF="156cb0da12f6c7b1c697f90b5f22d5e14be31165"

COPY codex-acp-fork-0.14.0.patch /tmp/dokploy-codex-acp-fork.patch
RUN --mount=type=cache,id=dokploy-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=dokploy-apt-lists,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      libssl-dev libcap-dev protobuf-compiler
RUN --mount=type=cache,id=dokploy-cargo-registry,target=/root/.cargo/registry,sharing=locked \
    --mount=type=cache,id=dokploy-cargo-git,target=/root/.cargo/git,sharing=locked \
    --mount=type=cache,id=dokploy-codex-acp-target,target=/tmp/cargo-target,sharing=locked \
    --mount=type=cache,id=dokploy-codex-acp-git,target=/tmp/codex-acp-git,sharing=locked \
    if [ ! -d /tmp/codex-acp-git/mirror.git ]; then \
      git clone --mirror "${CODEX_ACP_REPO}" /tmp/codex-acp-git/mirror.git; \
    else \
      git -C /tmp/codex-acp-git/mirror.git remote set-url origin "${CODEX_ACP_REPO}" \
      && git -C /tmp/codex-acp-git/mirror.git fetch --prune origin; \
    fi \
    && git clone /tmp/codex-acp-git/mirror.git /tmp/codex-acp \
    && cd /tmp/codex-acp \
    && git checkout "${CODEX_ACP_REF}" \
    && rm -f rust-toolchain.toml \
    && patch -p1 < /tmp/dokploy-codex-acp-fork.patch \
    && CARGO_TARGET_DIR=/tmp/cargo-target cargo build --release --bin codex-acp \
    && install -m 0755 /tmp/cargo-target/release/codex-acp /tmp/dokploy-codex-acp \
    && test -x /tmp/dokploy-codex-acp

FROM ubuntu:24.04 AS repository-source

ARG GIT_URL="<GIT_URL>"
ARG GIT_BRANCH="<GIT_BRANCH>"
ARG ENABLE_SUBMODULES="false"
ARG GIT_TAG_WINDOW="5"
ARG DEBIAN_FRONTEND=noninteractive
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY \
    HTTPS_PROXY=$HTTPS_PROXY \
    NO_PROXY=$NO_PROXY \
    http_proxy=$http_proxy \
    https_proxy=$https_proxy \
    no_proxy=$no_proxy

RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.ustc.edu.cn/ubuntu/|g; s|http://security.ubuntu.com/ubuntu/|http://mirrors.ustc.edu.cn/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources

RUN rm -f /etc/apt/apt.conf.d/docker-clean \
    && printf '%s\n' 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
      > /etc/apt/apt.conf.d/keep-cache

RUN --mount=type=cache,id=dokploy-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=dokploy-apt-lists,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

RUN set -eux; \
    git init repo; \
    cd repo; \
    git remote add origin "${GIT_URL}"; \
    git fetch --progress --depth=1 origin "refs/tags/*:refs/tags/*" || true; \
    tags="$(git for-each-ref --sort=-creatordate --format="%(refname:short)" refs/tags \
      | head -n "${GIT_TAG_WINDOW}")"; \
    if [ -n "${tags}" ]; then \
      selected_tags="$(printf '%s\n' ${tags} | tr '\n' ' ')"; \
      git for-each-ref --format="%(refname) %(refname:short)" refs/tags \
        | while read -r ref tag; do \
            case " ${selected_tags} " in \
              *" ${tag} "*) ;; \
              *) git update-ref -d "${ref}" ;; \
            esac; \
          done; \
      git reflog expire --expire=now --all; \
      git gc --prune=now; \
      oldest_tag_date="$(for tag in ${tags}; do git log -1 --format=%cI "refs/tags/${tag}"; done | sort | head -n 1)"; \
      fetch_since="$(date -u -d "${oldest_tag_date} - 1 day" +%Y-%m-%dT%H:%M:%SZ)"; \
      fetch_args="--shallow-since=${fetch_since}"; \
    else \
      fetch_args="--depth=200"; \
    fi; \
    if git ls-remote --exit-code --heads origin "${GIT_BRANCH}" >/dev/null; then \
      git fetch --progress ${fetch_args} origin "refs/heads/${GIT_BRANCH}:refs/remotes/origin/${GIT_BRANCH}"; \
      git checkout -B "${GIT_BRANCH}" "refs/remotes/origin/${GIT_BRANCH}"; \
    elif git ls-remote --exit-code --tags origin "${GIT_BRANCH}" >/dev/null; then \
      git fetch --progress --depth=1 origin "refs/tags/${GIT_BRANCH}:refs/tags/${GIT_BRANCH}"; \
      git checkout --detach "refs/tags/${GIT_BRANCH}"; \
    else \
      git fetch --progress ${fetch_args} origin "${GIT_BRANCH}"; \
      git checkout --detach FETCH_HEAD; \
    fi; \
    if [ "${ENABLE_SUBMODULES}" = "true" ]; then \
      git submodule update --init --recursive --depth=1; \
    fi

FROM tools AS final

COPY --from=codex-acp-builder /tmp/dokploy-codex-acp /usr/local/bin/dokploy-codex-acp
RUN install -m 0755 /usr/local/bin/dokploy-codex-acp \
      /root/.local/share/sandbox-agent/bin/agent_processes/codex-acp \
    && test -x /root/.local/share/sandbox-agent/bin/agent_processes/codex-acp

WORKDIR /workspace

COPY --from=repository-source /workspace/repo /workspace/repo

WORKDIR /workspace/repo

CMD ["/bin/bash"]
