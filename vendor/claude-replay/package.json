{
  "name": "claude-replay",
  "version": "0.8.1",
  "description": "Convert Claude Code, Cursor, and Codex session transcripts into self-contained, embeddable HTML replays",
  "type": "module",
	"exports": {
		".": {
			"types": "./src/parser.mjs",
			"import": "./src/parser.mjs"
		},
		"./agent-stream": {
			"types": "./src/agent-stream.mjs.d.ts",
			"import": "./src/agent-stream.mjs"
		},
		"./agent-events": {
			"types": "./src/agent-events.mjs.d.ts",
			"import": "./src/agent-events.mjs"
		},
    "./browser": "./src/browser.mjs",
    "./parser": "./src/parser.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "claude-replay": "bin/claude-replay.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "template/"
  ],
  "scripts": {
    "build": "node scripts/build-template.mjs",
    "build:website": "node scripts/build-template.mjs && node scripts/build-website.mjs",
    "test": "node --test test/test-*.mjs",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "replay",
    "transcript",
    "html"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/es617/claude-replay"
  },
  "license": "MIT"
}
